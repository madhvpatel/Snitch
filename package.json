{
  "name": "snitch-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "certs:setup": "node scripts/setup-dev-certs.mjs",
    "dev:frontend": "vite",
    "dev:server": "npm --prefix server run dev",
    "dev:python": "cd python-backend && python3 app.py",
    "dev:stack": "concurrently -k -n frontend,api,ai \"npm:dev:frontend\" \"npm:dev:server\" \"npm:dev:python\"",
    "build": "vite build",
    "export:source-training": "node scripts/export-source-training-data.mjs",
    "health:check": "node scripts/health-check.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "repair:rescore": "node scripts/rescore-reports.mjs",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.11"
  }
}
